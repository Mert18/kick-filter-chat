{
  "manifest_version": 3,
  "name": "Kick Chat Filter",
  "version": "1.0.0",
  "description": "Filter messages in Kick chat",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://kick.com/*"],
  "content_scripts": [
    {
      "matches": ["https://kick.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Kick Chat Filter"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "kick-chat-filter@yourdomain.com",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
